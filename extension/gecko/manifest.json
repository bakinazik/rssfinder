{
    "manifest_version": 2,
    "name": "__MSG_extensionName__",
    "version": "1.0.1",
    "description": "__MSG_extensionDescription__",
    "default_locale": "en",
    "permissions": [
        "activeTab",
        "tabs",
        "webNavigation",
        "storage",
        "clipboardWrite",
        "http://*/*",
        "https://*/*"
    ],
    "browser_action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "dist/16x16.png",
            "32": "dist/32x32.png",
            "48": "dist/48x48.png",
            "128": "dist/128x128.png"
        },
        "default_title": "__MSG_defaultTitle__"
    },
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "icons": {
        "16": "dist/16x16.png",
        "32": "dist/32x32.png",
        "48": "dist/48x48.png",
        "128": "dist/128x128.png"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "rssfinder@extension",
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "required": [
                    "none"
                ],
                "optional": []
            }
        }
    }
}